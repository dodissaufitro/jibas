# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this to .env in production server and update values

# Application
APP_NAME="JIBAS - Sistem Informasi Sekolah"
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Locale
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

# Maintenance
APP_MAINTENANCE_DRIVER=file

# Security - BCrypt rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error  # Only log errors/critical in production

# Database - UPDATE WITH YOUR PRODUCTION CREDENTIALS
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jibas_production
DB_USERNAME=jibas_user
DB_PASSWORD=STRONG_DATABASE_PASSWORD_HERE

# Session Security - CRITICAL FOR PRODUCTION
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true              # ✅ ENABLE ENCRYPTION
SESSION_SECURE_COOKIE=true        # ✅ HTTPS ONLY
SESSION_HTTP_ONLY=true            # ✅ PREVENT XSS
SESSION_SAME_SITE=lax            # ✅ CSRF PROTECTION
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting
BROADCAST_CONNECTION=log

# Filesystem
FILESYSTEM_DISK=local

# Queue
QUEUE_CONNECTION=database

# Cache
CACHE_STORE=database
# CACHE_PREFIX=jibas_  # Optional: prefix untuk shared cache servers

# Memcached (if using)
# MEMCACHED_HOST=127.0.0.1

# Redis (if using)
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Mail Configuration - UPDATE WITH YOUR MAIL SERVER
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (if using S3 for file storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite
VITE_APP_NAME="${APP_NAME}"

# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# Password Security Policies
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_EXPIRES_DAYS=90           # Force password change every 90 days (null = never)
PASSWORD_PREVENT_REUSE=5           # Prevent reusing last 5 passwords
PASSWORD_FORCE_FIRST_CHANGE=true   # Force change password on first login

# Rate Limiting Configuration
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_DECAY=15          # Minutes to wait after max attempts
RATE_LIMIT_API_REQUESTS=60
RATE_LIMIT_API_PER_MINUTES=1

# File Upload Security
MAX_UPLOAD_SIZE=2048                # KB (2MB default)
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp,gif
ALLOWED_DOCUMENT_EXTENSIONS=pdf,doc,docx,xls,xlsx

# Two-Factor Authentication (if implemented)
# 2FA_ENABLED=true
# 2FA_MANDATORY_FOR_ADMINS=true

# ==========================================
# MONITORING & LOGGING (Optional)
# ==========================================

# Sentry Error Tracking
# SENTRY_LARAVEL_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_TRACES_SAMPLE_RATE=0.2

# New Relic APM
# NEW_RELIC_APP_NAME="${APP_NAME}"
# NEW_RELIC_LICENSE_KEY=

# Bugsnag
# BUGSNAG_API_KEY=

# ==========================================
# BACKUP CONFIGURATION
# ==========================================

# Backup Settings (if using spatie/laravel-backup)
# BACKUP_ENABLED=true
# BACKUP_DISK=s3
# BACKUP_NOTIFICATIONS_MAIL=admin@yourdomain.com
# BACKUP_NOTIFICATIONS_SLACK=

# ==========================================
# TRUSTED PROXIES (if behind load balancer)
# ==========================================

# TRUSTED_PROXIES=*
# TRUST_ALL_PROXIES=true

# ==========================================
# PRODUCTION CHECKLIST VERIFICATION
# ==========================================

# Before going live, verify:
# [ ] APP_DEBUG=false
# [ ] APP_ENV=production
# [ ] Strong APP_KEY generated
# [ ] All SESSION_* security settings enabled
# [ ] Strong database credentials
# [ ] HTTPS configured (APP_URL uses https://)
# [ ] Mail configuration tested
# [ ] Backup system configured and tested
# [ ] Error monitoring setup (Sentry/Bugsnag)
# [ ] Rate limiting configured
# [ ] All sensitive data encrypted
# [ ] .env file permissions: chmod 600 .env
# [ ] Storage permissions: chmod -R 775 storage bootstrap/cache

# ==========================================
# NOTES
# ==========================================

# 1. NEVER commit this file to version control
# 2. Keep a secure backup of this file
# 3. Rotate APP_KEY and credentials regularly
# 4. Review security settings quarterly
# 5. Monitor logs for suspicious activities
# 6. Keep Laravel and dependencies updated
# 7. Perform regular security audits
# 8. Test backup restoration quarterly
